<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.geoagent.ui.chat.WaveBarsLoadingView
        android:id="@+id/wave_loading"
        android:layout_width="56dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        app:animationDuration="800"
        app:barColorEnd="@color/geoagent_red_air"
        app:barColorStart="@color/geoagent_blue_air"
        app:barCornerRadius="8dp"
        app:barCount="4"
        app:flowDuration="2000"
        app:highlightColor="@color/geoagent_yellow_air" />
</FrameLayout>
