<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Text Appearances ── -->

    <style name="TextAppearance.GeoAgent.DisplayLarge" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="lineHeight">36dp</item>
    </style>

    <style name="TextAppearance.GeoAgent.HeadlineMedium" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="lineHeight">28dp</item>
    </style>

    <style name="TextAppearance.GeoAgent.TitleLarge" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="lineHeight">24dp</item>
    </style>

    <style name="TextAppearance.GeoAgent.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24dp</item>
    </style>

    <style name="TextAppearance.GeoAgent.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20dp</item>
    </style>

    <style name="TextAppearance.GeoAgent.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="lineHeight">16dp</item>
    </style>

    <!-- Legacy compat -->
    <style name="TextAppearance.GeoAgent.Title" parent="TextAppearance.GeoAgent.TitleLarge" />
    <style name="TextAppearance.GeoAgent.Body" parent="TextAppearance.GeoAgent.BodyMedium" />
    <style name="TextAppearance.GeoAgent.Caption" parent="TextAppearance.GeoAgent.LabelSmall" />

    <!-- ── Cards ── -->

    <style name="Widget.GeoAgent.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.GeoAgent.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.GeoAgent.AuthInput" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="cardCornerRadius">26dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ── Composer Card ── -->

    <style name="Widget.GeoAgent.Composer" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_composer</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">0.5dp</item>
    </style>

    <style name="Widget.GeoAgent.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/text_muted</item>
    </style>

    <!-- ── Buttons ── -->

    <style name="Widget.GeoAgent.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.GeoAgent.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ── Chips ── -->

    <style name="Widget.GeoAgent.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/chip_border</item>
        <item name="chipStrokeWidth">0.5dp</item>
        <item name="chipCornerRadius">@dimen/radius_full</item>
        <item name="android:textColor">@color/on_background</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- ── Segment Switch ── -->

    <!-- ── Toolbar ── -->

    <style name="Widget.GeoAgent.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/on_background</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- ── Segment Switch ── -->

    <style name="Widget.GeoAgent.SegmentButton" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@drawable/bg_segment_unselected</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

</resources>
